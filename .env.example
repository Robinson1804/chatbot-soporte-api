# ─── Chatbot Mesa de Ayuda OTIN — Variables de entorno ───────────────────────
# Copiá este archivo a .env y completá los valores antes de iniciar el servidor.
# NUNCA commitees el archivo .env con valores reales.

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000

# Origen permitido para CORS (dejar en blanco para permitir cualquiera en dev)
# Ejemplo producción: https://chatbot.inei.gob.pe
ALLOWED_ORIGIN=

# ── Gemini API ────────────────────────────────────────────────────────────────
# Clave de API de Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres:password@localhost:5432/chatbot_otin

# ── Automatización SSI (Playwright) ──────────────────────────────────────────
# Credenciales del usuario que crea tickets en el portal SSI del INEI
SSI_USER=tu_usuario_ssi
SSI_PASS=tu_contraseña_ssi

# Ejecutar Playwright en modo headless (true = sin ventana, recomendado en servidor)
PLAYWRIGHT_HEADLESS=true

# ── Opciones de desarrollo / debug ───────────────────────────────────────────
# Saltar validación de horario laboral (true para pruebas fuera de horario)
SKIP_HORARIO=false

# Saltar validación de IP interna (true para pruebas en local)
SKIP_IP_VALIDATION=false

# Rango de IP internas permitidas para acceder a /admin y /api/ticket-ssi
# Formato CIDR: 192.168.1.0/24 | Para desarrollo local usar: 127.0.0.1/32
INTERNAL_IP_RANGE=192.168.1.0/24

# Token secreto para acceder al admin dashboard desde internet (Railway deploy)
ADMIN_TOKEN=cambia_esto_por_un_token_secreto_largo
